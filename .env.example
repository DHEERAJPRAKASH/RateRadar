# ---------------------------------------------------------------------------
# Rate-Tracker environment.  Copy to `.env` and fill in real values.
# The app FAILS FAST at startup if any *required* variable below is missing.
# No secrets are committed to the repo.
# ---------------------------------------------------------------------------

# --- Django (required) ---
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-please-use-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,.localband.com

# --- Postgres (required) ---
POSTGRES_DB=rateradar
POSTGRES_USER=rateradar
POSTGRES_PASSWORD=rateradar
POSTGRES_HOST=db
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# --- Redis (cache + Celery broker) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Scheduling ---
# How often the scrape worker runs, in seconds.
SCRAPE_INTERVAL_SECONDS=300

# --- API auth (required) ---
# Bearer token required by POST /rates/ingest. Rotate freely.
INGEST_API_TOKEN=dev-ingest-token-change-me

# --- API tuning ---
API_DEFAULT_PAGE_SIZE=50

# --- Observability ---
LOG_LEVEL=INFO
SLOW_QUERY_MS=200

# --- CORS / frontend ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
